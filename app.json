{
  "expo": {
    "assetBundlePatterns": [
      "assets/*",
      "assets/**/*"
    ],
    "name": "banknotesrf",
    "slug": "banknotesrf",
    "version": "3.0.1",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "banknotesrf",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "ru.cbr.banknotesrf"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#068E8E",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "package": "ru.cbr.banknotesrf"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-asset",
        {
          "assets": ["./assets/database/bnkdb.db"]
        }
      ],
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "react-native-vision-camera",
        {
          "cameraPermissionText": "Разрешите доступ к камере для распознавания банкнот",
          "enableMicrophonePermission": false,
          "disableFrameProcessors": false
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "compassDataEnable": true
    }
  }
}
